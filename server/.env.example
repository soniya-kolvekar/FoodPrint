# Server Configuration
PORT=5000

# 3rd Party APIs
SPOONACULAR_API_KEY="your_spoonacular_api_key_here"
UNSPLASH_ACCESS_KEY="your_unsplash_access_key_here"

# ============== GEMINI VISION APIS ==============
# Rotational keys for zero-downtime free tier fallback
GEMINI_API_KEY_1=your_first_free_key
GEMINI_API_KEY_2=your_second_free_key
GEMINI_API_KEY_3=your_third_free_key

# ============== FIREBASE ADMIN SDK ==============
# Required for backend authentication to work. 
# 1. Go to Firebase Console > Project Settings > Service Accounts 
# 2. Click "Generate new private key"
# 3. Save the JSON file in your server directory (it is ignored by git!)
# 4. Put the absolute path to that JSON file here:
GOOGLE_APPLICATION_CREDENTIALS="C:\\absolute\\path\\to\\your\\server\\firebase-service-account.json"
